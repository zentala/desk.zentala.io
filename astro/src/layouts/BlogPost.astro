---
import '../styles/global.css';

interface Props {
  title: string;
  date: string;
  author: string;
  tags: string[];
}

const { title, date, author, tags } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — zntlDesk Blog</title>
  <meta name="description" content={title}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <script defer data-domain="desk.zentala.io" src="https://plausible.io/js/script.js"></script>
</head>
<body>
  <article class="mx-auto max-w-[720px] px-4 py-16">
    <a href="/blog" class="text-sm text-muted hover:text-white transition-colors">
      &larr; Back to Blog
    </a>

    <header class="mt-8 mb-12">
      <h1 class="text-3xl font-bold sm:text-4xl leading-tight">
        {title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-muted">
        <time datetime={date}>{formattedDate}</time>
        <span>by {author}</span>
      </div>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <span class="rounded-full border border-gray-700 bg-dark-700 px-3 py-1 text-xs text-muted">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:mt-12 [&_h2]:mb-4
      [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:mt-8 [&_h3]:mb-3
      [&_p]:text-gray-300 [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:text-gray-300
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:text-gray-300
      [&_li]:mb-2
      [&_strong]:text-gray-100
      [&_a]:text-brand-green [&_a]:underline [&_a:hover]:text-brand-green-light
      [&_blockquote]:border-l-2 [&_blockquote]:border-brand-green/40 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-gray-400
      [&_hr]:border-gray-800 [&_hr]:my-8">
      <slot />
    </div>

    <footer class="mt-16 border-t border-gray-800 pt-8">
      <a href="/blog" class="text-sm text-muted hover:text-white transition-colors">
        &larr; Back to Blog
      </a>
    </footer>
  </article>
</body>
</html>
