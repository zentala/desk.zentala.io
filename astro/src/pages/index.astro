---
import Hero from '../components/Hero.tsx';
import Problem from '../components/Problem.tsx';
import Story from '../components/Story.tsx';
import HowItWorks from '../components/HowItWorks.tsx';
import Features from '../components/Features.tsx';
import Screenshots from '../components/Screenshots.tsx';
import Pricing from '../components/Pricing.tsx';
import FAQ from '../components/FAQ.tsx';
import Footer from '../components/Footer.tsx';
import WaitlistForm from '../components/WaitlistForm.tsx';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO: Title & Description -->
  <title>zntlDesk — Automatic Sit/Stand Tracker for Height-Adjustable Desks</title>
  <meta name="description" content="A tiny sensor that mounts under your desk, tracks your sitting and standing time, and actually gets you to move. Open source. No cloud. Pre-order from €49.">
  <meta name="keywords" content="standing desk sensor, sit stand tracker, desk ergonomics, posture tracker, open source, desk height sensor, ergonomic reminder">
  <link rel="canonical" href="https://desk.zentala.io">

  <!-- Open Graph -->
  <meta property="og:title" content="zntlDesk — Automatic Sit/Stand Tracker for Height-Adjustable Desks">
  <meta property="og:description" content="A tiny sensor that mounts under your desk, tracks your sitting time, and actually gets you to stand up. Open source. No cloud. From €49.">
  <meta property="og:type" content="product">
  <meta property="og:url" content="https://desk.zentala.io">
  <meta property="og:image" content="https://desk.zentala.io/images/og-cover.png">
  <meta property="og:site_name" content="zntlDesk">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="zntlDesk — Automatic Sit/Stand Tracker for Height-Adjustable Desks">
  <meta name="twitter:description" content="A tiny sensor that mounts under your desk, tracks your sitting time, and actually gets you to stand up. Open source. No cloud. From €49.">
  <meta name="twitter:image" content="https://desk.zentala.io/images/og-cover.png">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Plausible Analytics — privacy-first, no cookies, GDPR-compliant -->
  <script defer data-domain="desk.zentala.io" src="https://plausible.io/js/script.js"></script>

  <!-- Schema.org Product JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "zntlDesk — Sit/Stand Desk Sensor",
    "description": "Open source desk sensor that tracks sitting and standing time and nudges you to move. Mounts under any height-adjustable desk.",
    "brand": { "@type": "Brand", "name": "zntlDesk" },
    "url": "https://desk.zentala.io",
    "image": "https://desk.zentala.io/images/og-cover.png",
    "offers": [
      {
        "@type": "Offer",
        "name": "Basic Kit",
        "price": "49.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/PreOrder",
        "url": "https://desk.zentala.io/#pricing"
      },
      {
        "@type": "Offer",
        "name": "Pro Kit",
        "price": "79.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/PreOrder",
        "url": "https://desk.zentala.io/#pricing"
      },
      {
        "@type": "Offer",
        "name": "Founder's Edition",
        "price": "149.00",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/PreOrder",
        "url": "https://desk.zentala.io/#pricing"
      }
    ]
  }
  </script>
</head>
<body>
  <Hero />
  <section class="py-12 border-t border-gray-800/50">
    <div class="section-container max-w-2xl">
      <WaitlistForm client:load />
    </div>
  </section>
  <Problem />
  <Story />
  <HowItWorks />
  <Features />
  <Screenshots />
  <Pricing client:load />
  <FAQ client:load />
  <Footer client:load />
</body>
</html>
