---
import Hero from '../components/Hero.tsx';
import Stats from '../components/Stats.tsx';
import PostMortem from '../components/PostMortem.tsx';
import Architecture from '../components/Architecture.tsx';
import Behavior from '../components/Behavior.tsx';
import Background from '../components/Background.tsx';
import HardwareAppendix from '../components/HardwareAppendix.tsx';
import Software from '../components/Software.tsx';
import Goals from '../components/Goals.tsx';
import Licensing from '../components/Licensing.tsx';
import CTA from '../components/CTA.tsx';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SmartDesk R&D</title>
  <meta name="description" content="SmartDesk is a smart height-adjustable desk project focused on behavior change, modular architecture, and an open communication standard.">
  <meta name="keywords" content="SmartDesk, smart height-adjustable desk, height adjustable desk, smart desk, ergonomics, behavior change, standing desk">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <Hero />
  <Stats />
  <main class="container my-5">
    <PostMortem />
    <Architecture />
    <Behavior />
    <Background />
    <CTA />
    <HardwareAppendix />
    <Software />
    <Goals />
    <Licensing />
  </main>
</body>
</html>
